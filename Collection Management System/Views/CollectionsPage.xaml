<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Collection_Management_System.Models"
             xmlns:viewmodels="clr-namespace:Collection_Management_System.ViewModels"
             x:Class="Collection_Management_System.Views.CollectionsPage"
             Title="My Collections">

    <!-- Zmieniamy definicję wierszy: 
         Auto (tytuł), Auto (dodawanie), * (lista zajmuje resztę miejsca) -->
    <Grid RowDefinitions="Auto, Auto, *" Padding="20">
        
        <!-- 1. TYTUŁ (Row 0) -->
        <Label Text="Collection Management System" 
               FontSize="28" FontAttributes="Bold" 
               HorizontalOptions="Center" Margin="0,0,0,10" Grid.Row="0"/>

        <!-- 2. SEKCJA DODAWANIA (Row 1) - Teraz pod tytułem -->
        <VerticalStackLayout Grid.Row="1" Spacing="15" Margin="0,10,0,20">
            <Entry x:Name="NewCollectionEntry" 
                   Placeholder="Enter new collection name..." 
                   FontSize="20"
                   HeightRequest="60"
                   HorizontalOptions="Fill"/>
            
            <Button Text="ADD NEW COLLECTION" 
                    Clicked="OnAddCollectionClicked"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="White"
                    HeightRequest="60"
                    BackgroundColor="{StaticResource Primary}"/>
        </VerticalStackLayout>

        <!-- 3. LISTA KOLEKCJI (Row 2) - Na samym dole -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Collections}" SelectionMode="Single" SelectionChanged="OnCollectionSelected">
            <CollectionView.Header>
                <Label Text="Your Collections:" FontSize="16" Margin="0,0,0,10" TextColor="Gray"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UserCollection">
                    <Frame Margin="0,10" Padding="15" BorderColor="Gray" CornerRadius="10">
                        <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
