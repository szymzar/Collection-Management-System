<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Collection_Management_System.Models"
             xmlns:viewmodels="clr-namespace:Collection_Management_System.ViewModels"
             x:Class="Collection_Management_System.Views.CollectionsPage"
             Title="My Collections">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <Label Text="Collection Management System" 
               FontSize="24" FontAttributes="Bold" 
               HorizontalOptions="Center" Margin="0,0,0,20" Grid.Row="0"/>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Collections}" SelectionMode="Single" SelectionChanged="OnCollectionSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UserCollection">
                    <Frame Margin="0,5" Padding="15" BorderColor="Gray">
                        <Label Text="{Binding Name}" FontSize="18"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="0,20,0,0">
            <Entry x:Name="NewCollectionEntry" Placeholder="New collection name" WidthRequest="250"/>
            <Button Text="Add" Clicked="OnAddCollectionClicked"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
