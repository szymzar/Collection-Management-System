<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collection_Management_System.Views.ItemEditPage"
             Title="Edit Item">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Item name:"/>
        <Entry x:Name="NameEntry" Placeholder="Enter name"/>

        <Label Text="Description:"/>
        <Editor x:Name="DescriptionEditor" Placeholder="Enter description" HeightRequest="100"/>

        <Button Text="Save" Clicked="OnSaveClicked"/>
        <Button x:Name="DeleteButton" Text="Delete" Clicked="OnDeleteClicked" BackgroundColor="Red"/>
    </VerticalStackLayout>
</ContentPage>
